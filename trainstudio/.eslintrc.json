{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "globals": {
    "d3": "readonly",
    "XLSX": "readonly",
    "STATE": "writable",
    "chartState": "writable",
    "StateManager": "readonly",
    "DOM": "readonly",
    "PLAN_COLORS": "readonly",
    "formatTimeHHMM": "readonly",
    "parseTimeHHMM": "readonly",
    "showToast": "readonly",
    "openModal": "readonly",
    "closeModal": "readonly",
    "generateId": "readonly",
    "pushUndo": "readonly",
    "undo": "readonly",
    "redo": "readonly",
    "snapshotState": "readonly",
    "restoreSnapshot": "readonly",
    "updateUndoButtons": "readonly",
    "buildTripTimesForService": "readonly",
    "constrainTime": "readonly",
    "applyTimeDelta": "readonly",
    "enforceConstraints": "readonly",
    "populateCorridorSelect": "readonly",
    "populateAddPlanModal": "readonly",
    "createServicePlan": "readonly",
    "updatePlansModal": "readonly",
    "togglePlanVisibility": "readonly",
    "deletePlan": "readonly",
    "initChart": "readonly",
    "updateChart": "readonly",
    "updateLegend": "readonly",
    "selectService": "readonly",
    "highlightSelectedService": "readonly",
    "applyZoomScale": "readonly",
    "updateYAxis": "readonly",
    "buildServicePoints": "readonly",
    "renderDraggableNodes": "readonly",
    "updateAllNodePositions": "readonly",
    "updateServicePath": "readonly",
    "renderXAxis": "readonly",
    "clearChartLayers": "readonly",
    "setupYScaleDomain": "readonly",
    "setupXScaleDomain": "readonly",
    "renderEmptyChart": "readonly",
    "renderSingleTrackLayer": "readonly",
    "renderServicePaths": "readonly",
    "renderSelectedServiceNodes": "readonly",
    "updateDetailPanel": "readonly",
    "hideDetailPanel": "readonly",
    "deleteService": "readonly",
    "onTimeEdit": "readonly",
    "updateTimeFilterInputs": "readonly",
    "applyTimeFilter": "readonly",
    "resetTimeFilter": "readonly",
    "makeTimeEditHandler": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "args": "none" }],
    "no-console": "off",
    "no-undef": "error",
    "semi": ["warn", "always"],
    "quotes": ["warn", "single", { "avoidEscape": true }],
    "indent": ["warn", 2, { "SwitchCase": 1 }],
    "comma-dangle": ["warn", "only-multiline"],
    "no-var": "warn",
    "prefer-const": "warn"
  }
}
